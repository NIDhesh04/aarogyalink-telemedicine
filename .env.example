# ──────────────────────────────────────────────────────────────
# AarogyaLink — Global Project Environment Template
# ──────────────────────────────────────────────────────────────

# ─── Backend Settings (Used in /backend) ──────────────────────
# development, production, or test
NODE_ENV=development
PORT=5005
# Optimized for your worker threads[cite: 1, 40]
UV_THREADPOOL_SIZE=16

# ─── Database & Cache ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/aarogyalink
REDIS_URL=redis://localhost:6379

# ─── Security (JWT) ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_backend_jwt_secret
JWT_REFRESH_SECRET=your_backend_refresh_secret

# ─── AI Triage (Google Gemini) ────────────────────────────────
# Get your FREE key at: https://aistudio.google.com/
GEMINI_API_KEY=your_free_gemini_api_key_here

# ─── Email (Nodemailer) ───────────────────────────────────────
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_character_app_password

# ─── Frontend Settings (Used in /frontend) ────────────────────
# The URL where your backend is running[cite: 3]
VITE_API_BASE_URL=http://localhost:5005/api